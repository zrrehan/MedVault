generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
    id        String   @id @default(uuid())
    email     String   @unique
    name      String
    password  String
    role      UserRole @default(CUSTOMER)  
    profilePicture String @default("https://i.ibb.co.com/hxDhZ9Pz/img.jpg")  
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    Medicines Medicine[]
    banned Boolean @default(false)

    order Order[]
}

enum UserRole {
    CUSTOMER
    SELLER 
    ADMIN
}


model Medicine {
    id String @id @default(uuid())
    name String 
    price Int
    stockQuantity Int 
    seller_id String
    seller User @relation(fields: [seller_id], references: [id]) 
    category String[]
    is_active Boolean
    manufacturer String 
    image String 
    description String 

    sold_data SoldData[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}


model Order {
    id String @id @default(uuid())
    delivery_state DeliveryStatus @default(PENDING)
    payment_state PaymentStatus @default(PENDING)
    sold_data SoldData[]
    userId String
    user User @relation(fields: [userId], references: [id])
}

enum DeliveryStatus {
    PENDING 
    SHIPPED 
    DELIVERED 
}

enum PaymentStatus {
    PENDING 
    PAID 
}

model SoldData {
    id String @id @default(uuid())
    medicineId String 
    medicine Medicine @relation(fields: [medicineId], references: [id])

    quantity Int 
    priceAtPurchase Int 

    orderId String 
    order Order @relation(fields: [orderId], references: [id])
}